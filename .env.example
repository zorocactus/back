# ── MedSmart Backend — variables d'environnement ──────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer .env dans git.

# Django
SECRET_KEY=django-insecure-change-this-in-production-use-env-variable
DEBUG=True
ALLOWED_HOSTS=*

# Base de données PostgreSQL
DB_NAME=medical_db
DB_USER=postgres
DB_PASSWORD=yassir
DB_HOST=localhost
DB_PORT=5432

# CORS
# En dev : CORS_ALLOW_ALL=True
# En prod : CORS_ALLOW_ALL=False et renseigner CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://medsmart.example.com
